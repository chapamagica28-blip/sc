local function main(targetName)
    local Players = game:GetService("Players")
    local Player = Players.LocalPlayer
    
    local function createLoadingHub()
        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "StellaHubLoading"
        screenGui.ResetOnSpawn = false
        screenGui.Parent = Player:WaitForChild("PlayerGui")
        
        local mainFrame = Instance.new("Frame")
        mainFrame.Name = "MainFrame"
        mainFrame.Size = UDim2.new(0, 400, 0, 200)
        mainFrame.Position = UDim2.new(0.5, -200, 0.5, -100)
        mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        mainFrame.BorderColor3 = Color3.fromRGB(255, 100, 0)
        mainFrame.BorderSizePixel = 3
        mainFrame.Parent = screenGui
        
        local titleLabel = Instance.new("TextLabel")
        titleLabel.Name = "Title"
        titleLabel.Text = "StellaHub"
        titleLabel.TextColor3 = Color3.fromRGB(255, 100, 0)
        titleLabel.BackgroundTransparency = 1
        titleLabel.Size = UDim2.new(1, 0, 0, 50)
        titleLabel.TextScaled = true
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.Parent = mainFrame
        
        local loadingLabel = Instance.new("TextLabel")
        loadingLabel.Name = "LoadingLabel"
        loadingLabel.Text = "Carregando"
        loadingLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        loadingLabel.BackgroundTransparency = 1
        loadingLabel.Size = UDim2.new(1, 0, 0, 30)
        loadingLabel.Position = UDim2.new(0, 0, 0, 50)
        loadingLabel.TextScaled = true
        loadingLabel.Font = Enum.Font.Gotham
        loadingLabel.Parent = mainFrame
        
        local barBackground = Instance.new("Frame")
        barBackground.Name = "BarBackground"
        barBackground.Size = UDim2.new(0.8, 0, 0, 20)
        barBackground.Position = UDim2.new(0.1, 0, 0, 90)
        barBackground.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        barBackground.BorderColor3 = Color3.fromRGB(255, 100, 0)
        barBackground.BorderSizePixel = 2
        barBackground.Parent = mainFrame
        
        local barFill = Instance.new("Frame")
        barFill.Name = "BarFill"
        barFill.Size = UDim2.new(0, 0, 1, 0)
        barFill.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
        barFill.BorderSizePixel = 0
        barFill.Parent = barBackground
        
        local percentLabel = Instance.new("TextLabel")
        percentLabel.Name = "Percent"
        percentLabel.Text = "0%"
        percentLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        percentLabel.BackgroundTransparency = 1
        percentLabel.Size = UDim2.new(1, 0, 0, 20)
        percentLabel.Position = UDim2.new(0, 0, 0, 120)
        percentLabel.TextScaled = true
        percentLabel.Font = Enum.Font.Gotham
        percentLabel.Parent = mainFrame
        
        return screenGui, barFill, percentLabel
    end
    
    local loadingGui, barFill, percentLabel = createLoadingHub()
    
    for i = 0, 100, 5 do
        barFill.Size = UDim2.new(i / 100, 0, 1, 0)
        percentLabel.Text = i .. "%"
        task.wait(0.05)
    end
    
    task.wait(0.5)
    loadingGui:Destroy()
    
    print("\n╔════════════════════════════════════╗")
    print("║  MOVESET STEALER - STELLA HUB      ║")
    print("╚════════════════════════════════════╝\n")
    print("🎯 Copiando de: " .. targetName)
    print("👤 Para: " .. Player.Name .. "\n")
    
    local function notify(title, text, color)
        color = color or Color3.fromRGB(255, 100, 0)
        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "Notif_" .. math.random(1, 99999)
        screenGui.ResetOnSpawn = false
        screenGui.Parent = Player:WaitForChild("PlayerGui")
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 350, 0, 120)
        frame.Position = UDim2.new(1, -20, 0, 20)
        frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        frame.BorderColor3 = color
        frame.BorderSizePixel = 3
        frame.Parent = screenGui
        
        local titleLabel = Instance.new("TextLabel")
        titleLabel.Text = title
        titleLabel.TextColor3 = color
        titleLabel.BackgroundTransparency = 1
        titleLabel.Size = UDim2.new(1, 0, 0, 45)
        titleLabel.TextScaled = true
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.Parent = frame
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Text = text
        textLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        textLabel.BackgroundTransparency = 1
        textLabel.Size = UDim2.new(1, 0, 1, -45)
        textLabel.Position = UDim2.new(0, 0, 0, 45)
        textLabel.TextScaled = true
        textLabel.Font = Enum.Font.Gotham
        textLabel.TextWrapped = true
        textLabel.Parent = frame
        
        task.wait(4)
        screenGui:Destroy()
    end
    
    -- ⬇️ AQUI ESTÁ A CORREÇÃO - Procura o ALVO, não a si mesmo ⬇️
    local targetPlayer = Players:FindFirstChild(targetName)
    
    if not targetPlayer then
        -- Se não encontrou, procura em todos
        for _, player in pairs(Players:GetPlayers()) do
            if player.Name == targetName then
                targetPlayer = player
                break
            end
        end
    end
    
    if not targetPlayer then
        notify("❌ ERRO", "Jogador " .. targetName .. " não encontrado!", Color3.fromRGB(255, 50, 50))
        print("❌ Jogador não encontrado: " .. targetName)
        print("\n📋 Jogadores disponíveis:")
        for _, player in pairs(Players:GetPlayers()) do
            print("  - " .. player.Name)
        end
        return
    end
    
    print("✅ Alvo encontrado: " .. targetPlayer.Name)
    
    -- Obtém statz do ALVO
    local targetStatz = targetPlayer:FindFirstChild("statz")
    if not targetStatz then
        notify("❌ ERRO", "statz do alvo não encontrado!", Color3.fromRGB(255, 50, 50))
        print("❌ statz do alvo não encontrado")
        return
    end
    
    print("✅ statz do alvo encontrado")
    
    -- Obtém movesetsaving do ALVO
    local targetMovesetsaving = targetStatz:FindFirstChild("movesetsaving")
    if not targetMovesetsaving then
        notify("❌ ERRO", "movesetsaving do alvo não encontrado!", Color3.fromRGB(255, 50, 50))
        print("❌ movesetsaving do alvo não encontrado")
        return
    end
    
    print("✅ movesetsaving do alvo encontrado\n")
    
    -- Obtém statz do PLAYER LOCAL (você)
    local myStatz = Player:FindFirstChild("statz")
    if not myStatz then
        notify("❌ ERRO", "Seu statz não existe!", Color3.fromRGB(255, 50, 50))
        print("❌ Seu statz não existe")
        return
    end
    
    print("✅ Seu statz encontrado")
    
    -- Obtém ou cria movesetsaving PARA VOCÊ
    local myMovesetsaving = myStatz:FindFirstChild("movesetsaving")
    if not myMovesetsaving then
        myMovesetsaving = Instance.new("Folder")
        myMovesetsaving.Name = "movesetsaving"
        myMovesetsaving.Parent = myStatz
        print("✅ movesetsaving criado para você\n")
    else
        print("✅ movesetsaving já existe em você\n")
    end
    
    print("[COPIANDO] Limpando seus saveX antigos...\n")
    
    -- Limpa seus saveX antigos
    for _, child in pairs(myMovesetsaving:GetChildren()) do
        child:Destroy()
    end
    
    print("[COPIANDO] Copiando saveX do alvo para você...\n")
    
    -- Copia os saveX DO ALVO PARA VOCÊ
    local copiedCount = 0
    for _, save in pairs(targetMovesetsaving:GetChildren()) do
        if string.match(save.Name, "save%d") then
            local clonedSave = save:Clone()
            clonedSave.Parent = myMovesetsaving
            copiedCount = copiedCount + 1
            
            local abilityCount = #clonedSave:GetChildren()
            print("[✅] " .. save.Name .. " copiado (" .. abilityCount .. " habilidades)")
        end
    end
    
    print("")
    
    if copiedCount == 0 then
        notify("❌ ERRO", "Nenhum save foi copiado!", Color3.fromRGB(255, 50, 50))
        return
    end
    
    print("╔════════════════════════════════════╗")
    print("║ ✅ MOVESET ROUBADO COM SUCESSO!   ║")
    print("╚════════════════════════════════════╝\n")
    print("📊 Total de saveX copiados: " .. copiedCount)
    print("👤 De: " .. targetPlayer.Name)
    print("👤 Para: " .. Player.Name .. "\n")
    
    notify("✅ SUCESSO!", "Roubado " .. copiedCount .. " saveX\nDe: " .. targetPlayer.Name, Color3.fromRGB(50, 255, 50))
end

if target_user then
    main(target_user)
else
    print("❌ ERRO: Defina target_user antes!")
    print("Exemplo: local target_user = 'IZACff007'")
end
