local myMovesetsaving = myStatz:FindFirstChild("movesetsaving")
if not myMovesetsaving then
    myMovesetsaving = Instance.new("Folder")
    myMovesetsaving.Name = "movesetsaving"
    myMovesetsaving.Parent = myStatz
    print("✅ movesetsaving criado\n")
else
    print("✅ movesetsaving já existe\n")
end

print("[COPIANDO] Limpando saveX antigos...\n")

-- Limpa os saveX antigos
for _, child in pairs(myMovesetsaving:GetChildren()) do
    child:Destroy()
end

print("[COPIANDO] Copiando novos saveX...\n")

-- Copia os saveX do alvo
local copiedCount = 0
for _, save in pairs(targetMovesetsaving:GetChildren()) do
    if string.match(save.Name, "save%d") then
        local clonedSave = save:Clone()
        clonedSave.Parent = myMovesetsaving
        copiedCount = copiedCount + 1
        
        local abilityCount = #clonedSave:GetChildren()
        print("[✅] " .. save.Name .. " copiado (" .. abilityCount .. " habilidades)")
        
        -- Log das habilidades principais
        local logCount = 0
        for _, ability in pairs(clonedSave:GetChildren()) do
            if logCount < 5 then
                print("    → " .. ability.Name .. " = " .. tostring(ability.Value))
                logCount = logCount + 1
            end
        end
        if abilityCount > 5 then
            print("    ... e mais " .. (abilityCount - 5) .. " habilidades")
        end
        print("")
    end
end

if copiedCount == 0 then
    notify("❌ ERRO", "Nenhum save foi copiado!", Color3.fromRGB(255, 50, 50))
    print("❌ Nenhum save foi copiado")
    return
end

